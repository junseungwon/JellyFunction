## 🔟 주석 규칙

### 📝 XML 주석 (권장)

```csharp
/// <summary>
/// 플레이어의 이동과 상호작용을 제어하는 메인 컨트롤러
/// </summary>
public class PlayerController : MonoBehaviour
{
    /// <summary>
    /// 플레이어의 이동 속도 (초당 유닛)
    /// </summary>
    [SerializeField] private float _moveSpeed = 5f;

    /// <summary>
    /// 플레이어에게 데미지를 입힙니다
    /// </summary>
    /// <param name="damage">입힐 데미지 양</param>
    /// <param name="hitPoint">피격 위치</param>
    /// <returns>데미지를 받았는지 여부</returns>
    public bool TakeDamage(float damage, Vector3 hitPoint)
    {
        // TODO: 무적 상태 체크 추가 필요
        _currentHealth -= damage;

        // FIXME: 체력이 음수가 될 수 있음
        if (_currentHealth <= 0)
        {
            Die();
            return true;
        }

        return false;
    }

    // NOTE: 이 메서드는 애니메이션 이벤트에서 호출됨
    private void OnAttackComplete()
    {
        _isAttacking = false;
    }
}

